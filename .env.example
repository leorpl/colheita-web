PORT=3000
HOST=127.0.0.1

# SQLite database file
DB_PATH=./data/app.db

# Domain settings
UMIDADE_BASE=0.13

# CORS
CORS_ORIGIN=http://localhost:3000

# Reverse proxy (set 1 when behind proxy/load balancer)
TRUST_PROXY=0

# Auth/session
AUTH_ENABLED=1
SESSION_TTL_DAYS=30
SESSION_COOKIE_NAME=st_session

# Cookie hardening
# Use 1 only behind HTTPS.
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax

# Rate limiting (in-memory)
RATE_LIMIT_ENABLED=1
RATE_LIMIT_API_WINDOW_MS=300000
RATE_LIMIT_API_MAX=2400
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=25

## DEV seed
# Em NODE_ENV=development, se o DB estiver vazio, o sistema cria usuarios *_test automaticamente.
