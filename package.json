{
  "name": "colheita-web",
  "version": "1.1.0",
  "description": "NazcaTraker: controle interno de colheita (viagens, descontos, sacas, fretes e relatorios).",
  "main": "index.js",
  "scripts": {
    "context:selfheal": "node scripts/self-heal-context.js",
    "context:check": "node scripts/self-heal-context.js --check",
    "context:watch": "nodemon --watch src --watch scripts --watch docs --watch package.json --watch .env.example --ext js,json,md --signal SIGINT --exec \"node scripts/self-heal-context.js\"",
    "predev": "node scripts/self-heal-context.js",
    "prestart": "node scripts/self-heal-context.js",
    "pretest": "node scripts/self-heal-context.js",
    "test": "node --test",
    "start": "node src/server.js",
    "dev": "nodemon --watch src --ext js,json --signal SIGINT src/server.js",
    "lint": "eslint .",
    "seed": "node scripts/seed-from-planilha.js",
    "seed:destino-regras": "node scripts/seed-destino-regras-from-planilha.js",
    "override:umidade:formiga-ap": "node scripts/override-umidade-formiga-ap.js",
    "override:umidade:tb02-go": "node scripts/override-umidade-tb02-go.js",
    "override:umidade:tb04-pmgp": "node scripts/override-umidade-tb04-pmgp.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.33.5",
    "shpjs": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "nodemon": "^3.1.14"
  }
}
