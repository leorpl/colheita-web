// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlantioTipo {
  id         Int     @id @default(autoincrement())
  nome       String  @unique @db.Text
  created_at String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at String? @db.Text

  @@map("plantio_tipo")
}

model Safra {
  id              Int     @id @default(autoincrement())
  safra           String  @unique @db.Text
  plantio         String? @db.Text
  data_referencia String? @db.Text
  area_ha         Float   @default(0)
  painel          Int     @default(0)
  created_at      String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at      String? @db.Text

  fretes                 Frete[]
  destino_regras         DestinoRegra[]
  destino_regras_plantio DestinoRegraPlantio[]
  talhoes_safra          TalhaoSafra[]
  viagens                Viagem[]

  @@map("safra")
}

model Talhao {
  id                Int     @id @default(autoincrement())
  codigo            String  @unique @db.Text
  local             String? @db.Text
  nome              String? @db.Text
  situacao          String? @db.Text
  hectares          Float   @default(0)
  posse             String? @db.Text
  contrato          String? @db.Text
  observacoes       String? @db.Text
  irrigacao         String? @db.Text
  foto_url          String? @db.Text
  maps_url          String? @db.Text
  tipo_solo         String? @db.Text
  calagem           String? @db.Text
  gessagem          String? @db.Text
  fosforo_corretivo String? @db.Text
  created_at        String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at        String? @db.Text

  talhoes_safra TalhaoSafra[]
  viagens       Viagem[]

  @@map("talhao")
}

model Destino {
  id           Int     @id @default(autoincrement())
  codigo       String  @unique @db.Text
  local        String  @db.Text
  maps_url     String? @db.Text
  trava_sacas  Float?
  distancia_km Float?
  observacoes  String? @db.Text
  created_at   String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at   String? @db.Text

  fretes                 Frete[]
  destino_regras         DestinoRegra[]
  destino_regras_plantio DestinoRegraPlantio[]
  viagens                Viagem[]

  @@map("destino")
}

model Motorista {
  id            Int     @id @default(autoincrement())
  nome          String  @unique @db.Text
  placa         String? @db.Text
  cpf           String? @db.Text
  banco         String? @db.Text
  pix_conta     String? @db.Text
  tipo_veiculo  String? @db.Text
  capacidade_kg Float?
  created_at    String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at    String? @db.Text

  fretes    Frete[]
  viagens   Viagem[]
  quitacoes MotoristaQuitacao[]
  usuarios  Usuario[]

  @@map("motorista")
}

model Frete {
  id             Int     @id @default(autoincrement())
  safra_id       Int
  motorista_id   Int
  destino_id     Int
  valor_por_saca Float
  created_at     String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at     String? @db.Text

  safra     Safra     @relation(fields: [safra_id], references: [id], onDelete: Cascade)
  motorista Motorista @relation(fields: [motorista_id], references: [id], onDelete: Cascade)
  destino   Destino   @relation(fields: [destino_id], references: [id], onDelete: Cascade)

  @@unique([safra_id, motorista_id, destino_id])
  @@index([safra_id])
  @@index([motorista_id])
  @@index([destino_id])
  @@map("frete")
}

model DestinoRegra {
  id                       Int     @id @default(autoincrement())
  safra_id                 Int
  destino_id               Int
  trava_sacas              Float?
  custo_silo_por_saca      Float   @default(0)
  custo_terceiros_por_saca Float   @default(0)
  impureza_limite_pct      Float   @default(0)
  ardidos_limite_pct       Float   @default(0)
  queimados_limite_pct     Float   @default(0)
  avariados_limite_pct     Float   @default(0)
  esverdiados_limite_pct   Float   @default(0)
  quebrados_limite_pct     Float   @default(0)
  created_at               String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at               String? @db.Text

  safra   Safra          @relation(fields: [safra_id], references: [id], onDelete: Cascade)
  destino Destino        @relation(fields: [destino_id], references: [id], onDelete: Cascade)
  faixas  UmidadeFaixa[]

  @@unique([safra_id, destino_id])
  @@index([safra_id, destino_id])
  @@map("destino_regra")
}

model DestinoRegraPlantio {
  id                       Int     @id @default(autoincrement())
  safra_id                 Int
  destino_id               Int
  tipo_plantio             String  @db.Text
  trava_sacas              Float?
  custo_silo_por_saca      Float   @default(0)
  custo_terceiros_por_saca Float   @default(0)
  impureza_limite_pct      Float   @default(0)
  ardidos_limite_pct       Float   @default(0)
  queimados_limite_pct     Float   @default(0)
  avariados_limite_pct     Float   @default(0)
  esverdiados_limite_pct   Float   @default(0)
  quebrados_limite_pct     Float   @default(0)
  created_at               String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at               String? @db.Text

  safra   Safra                 @relation(fields: [safra_id], references: [id], onDelete: Cascade)
  destino Destino               @relation(fields: [destino_id], references: [id], onDelete: Cascade)
  faixas  UmidadeFaixaPlantio[]

  @@unique([safra_id, destino_id, tipo_plantio])
  @@index([safra_id, destino_id])
  @@map("destino_regra_plantio")
}

model UmidadeFaixaPlantio {
  id                       Int     @id @default(autoincrement())
  destino_regra_plantio_id Int
  umid_gt                  Float
  umid_lte                 Float
  desconto_pct             Float
  custo_secagem_por_saca   Float   @default(0)
  created_at               String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at               String? @db.Text

  regra DestinoRegraPlantio @relation(fields: [destino_regra_plantio_id], references: [id], onDelete: Cascade)

  @@index([destino_regra_plantio_id])
  @@map("umidade_faixa_plantio")
}

model UmidadeFaixa {
  id                     Int     @id @default(autoincrement())
  destino_regra_id       Int
  umid_gt                Float
  umid_lte               Float
  desconto_pct           Float
  custo_secagem_por_saca Float   @default(0)
  created_at             String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at             String? @db.Text

  regra DestinoRegra @relation(fields: [destino_regra_id], references: [id], onDelete: Cascade)

  @@index([destino_regra_id])
  @@map("umidade_faixa")
}

model TalhaoSafra {
  id               Int     @id @default(autoincrement())
  safra_id         Int
  talhao_id        Int
  pct_area_colhida Float   @default(0)
  created_at       String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at       String? @db.Text

  safra  Safra  @relation(fields: [safra_id], references: [id], onDelete: Cascade)
  talhao Talhao @relation(fields: [talhao_id], references: [id], onDelete: Cascade)

  @@unique([safra_id, talhao_id])
  @@index([safra_id])
  @@index([talhao_id])
  @@map("talhao_safra")
}

model Viagem {
  id           Int     @id @default(autoincrement())
  ficha        String  @db.Text
  safra_id     Int
  tipo_plantio String? @db.Text
  talhao_id    Int
  local        String? @db.Text
  destino_id   Int
  motorista_id Int
  placa        String? @db.Text
  data_saida   String? @db.Text
  hora_saida   String? @db.Text
  data_entrega String? @db.Text
  hora_entrega String? @db.Text

  carga_total_kg Float
  tara_kg        Float

  umidade_pct Float @default(0)

  impureza_pct    Float @default(0)
  ardidos_pct     Float @default(0)
  queimados_pct   Float @default(0)
  avariados_pct   Float @default(0)
  esverdiados_pct Float @default(0)
  quebrados_pct   Float @default(0)

  impureza_limite_pct    Float @default(0)
  ardidos_limite_pct     Float @default(0)
  queimados_limite_pct   Float @default(0)
  avariados_limite_pct   Float @default(0)
  esverdiados_limite_pct Float @default(0)
  quebrados_limite_pct   Float @default(0)

  peso_bruto_kg           Float
  umidade_desc_pct        Float
  umidade_desc_pct_manual Float?
  umidade_kg              Float
  impureza_kg             Float
  ardidos_kg              Float
  queimados_kg            Float
  avariados_kg            Float
  esverdiados_kg          Float
  quebrados_kg            Float
  peso_limpo_seco_kg      Float
  sacas                   Float

  sacas_frete     Float
  frete_tabela    Float
  sub_total_frete Float

  secagem_custo_por_saca Float @default(0)
  sub_total_secagem      Float @default(0)

  custo_silo_por_saca      Float @default(0)
  sub_total_custo_silo     Float @default(0)
  abatimento_total_silo    Float @default(0)
  abatimento_por_saca_silo Float @default(0)

  custo_terceiros_por_saca      Float @default(0)
  sub_total_custo_terceiros     Float @default(0)
  abatimento_total_terceiros    Float @default(0)
  abatimento_por_saca_terceiros Float @default(0)

  created_at String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at String? @db.Text

  safra     Safra     @relation(fields: [safra_id], references: [id], onDelete: Restrict)
  talhao    Talhao    @relation(fields: [talhao_id], references: [id], onDelete: Restrict)
  destino   Destino   @relation(fields: [destino_id], references: [id], onDelete: Restrict)
  motorista Motorista @relation(fields: [motorista_id], references: [id], onDelete: Restrict)

  @@unique([safra_id, ficha])
  @@index([safra_id])
  @@index([destino_id])
  @@index([talhao_id])
  @@index([motorista_id])
  @@index([data_saida])
  @@map("viagem")
}

model MotoristaQuitacao {
  id              Int     @id @default(autoincrement())
  motorista_id    Int
  de              String  @db.Text
  ate             String  @db.Text
  data_pagamento  String  @db.Text
  valor           Float
  forma_pagamento String? @db.Text
  observacoes     String? @db.Text
  created_at      String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at      String? @db.Text

  motorista Motorista @relation(fields: [motorista_id], references: [id], onDelete: Cascade)

  @@index([motorista_id])
  @@index([de, ate])
  @@index([data_pagamento])
  @@map("motorista_quitacao")
}

model Usuario {
  id            Int     @id @default(autoincrement())
  username      String  @unique @db.Text
  nome          String? @db.Text
  role          String  @db.Text
  motorista_id  Int?
  menus_json    String? @db.Text
  password_hash String  @db.Text
  password_salt String  @db.Text
  active        Int     @default(1)
  created_at    String  @default(dbgenerated("(now())::text")) @db.Text
  updated_at    String? @db.Text

  motorista Motorista?      @relation(fields: [motorista_id], references: [id], onDelete: SetNull)
  sessoes   UsuarioSessao[]

  @@map("usuario")
}

model UsuarioSessao {
  id         Int    @id @default(autoincrement())
  usuario_id Int
  token_hash String @unique @db.Text
  expires_at String @db.Text
  created_at String @default(dbgenerated("(now())::text")) @db.Text

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@index([expires_at])
  @@map("usuario_sessao")
}
